# Copy this to /opt/narval/.env on the droplet and fill in all values.
# Generate strong passwords: openssl rand -hex 32

# === Postgres ===
POSTGRES_PASSWORD=           # strong password, used by all services

# === MinIO ===
# Must NOT be "narval" — server rejects it as insecure in production
MINIO_ROOT_USER=narval-app
MINIO_ROOT_PASSWORD=         # strong password

# === Umami ===
UMAMI_APP_SECRET=            # openssl rand -hex 32

# === Email (Resend) ===
RESEND_API_KEY=              # from resend.com — requires gonarval.com domain verified
EMAIL_FROM=noreply@gonarval.com
EMAIL_FROM_NAME=Narval

# === Server ===
ENV=production
PORT=8080
DATABASE_URL=postgresql://narval:POSTGRES_PASSWORD_HERE@postgres:5432/narval?sslmode=disable
REDIS_ADDR=redis:6379
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=narval-app          # must match MINIO_ROOT_USER above
MINIO_SECRET_KEY=MINIO_ROOT_PASSWORD_HERE  # must match MINIO_ROOT_PASSWORD above
MINIO_BUCKET=narval
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=https://storage.gonarval.com
SUPERTOKENS_CONNECTION_URI=http://supertokens:3567
SUPERTOKENS_API_KEY=
CORS_ORIGINS=https://gonarval.com

# === Web ===
INTERNAL_API_URL=http://server:8080/api/v1
UMAMI_URL=http://umami:3000
UMAMI_WEBSITE_ID=            # fill after first Umami login at gonarval.com/analytics

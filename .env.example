# =============================================================================
# Local development environment (.env)
# Copy to .env:  cp .env.example .env  — then fill in the real third-party keys.
#
# This file is consumed by:
#   - docker-compose.yml   (NEXT_PUBLIC_MAPBOX_TOKEN, RESEND_API_KEY, UMAMI_WEBSITE_ID)
#   - scripts/seed         (loads ../../.env — needs the MinIO creds below)
#
# Postgres/MinIO creds are HARDCODED to narval/narval_secret in
# docker-compose.yml for local dev, so the values below must match them.
# Do NOT randomize the local creds — the seed connects with exactly these.
# =============================================================================

# === MinIO (object storage) ===
# Must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose.yml.
MINIO_ACCESS_KEY=narval
MINIO_SECRET_KEY=narval_secret

# === Mapbox (map rendering) — REQUIRED ===
# Get a public token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# === Email (Resend + Zoho SMTP) ===
# Resend API key from https://resend.com (requires gonarval.com verified).
# Optional locally — emails just won't send.
RESEND_API_KEY=re_your_resend_key_here
# Zoho Mail password / app-specific password for contact@gonarval.com.
# See https://accounts.zoho.eu/home#security/application-specific-passwords
SMTP_PASSWORD=your_zoho_password_here

# === Admin ===
# Comma-separated emails allowed to seed startup shells ("New profile").
# Optional — leave empty to disable admin shell creation.
ADMIN_EMAILS=albmf@protonmail.com

# === Umami (analytics) ===
# Website IDs are created in the Umami UI; copy them here. Optional locally.
UMAMI_WEBSITE_ID=your_umami_website_id_here
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id_here
# Admin password for the local Umami login (default user: admin).
# Generated value — replace if you like:  head -c16 /dev/urandom | od -An -tx1 | tr -d ' '
UMAMI_ADMIN_PASSWORD=499c1828c697794c0b3855b3d0122ebf

# === Secrets (generate your own) ===
# Random strings. Generate with: head -c32 /dev/urandom | od -An -tx1 | tr -d ' '
# (or `openssl rand -hex 32` if openssl is available)
UMAMI_APP_SECRET=cf909ba2762ce24c35783c12157205cee4430fa7c94fea6d4f39f55303d1ea54
SUPERTOKENS_API_KEY=585ead4459631e8e56f748b82a840971f78d720930e754dd875a44acc0135f83

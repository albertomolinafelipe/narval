#!/bin/sh
# Narval pre-push hook — catch what CI would reject before it leaves the machine.
# Skip with: git push --no-verify

set -e

echo "pre-push: lint check..."
if ! make lint-check; then
    echo ""
    echo "Lint check failed — fix with: make lint"
    exit 1
fi

echo "pre-push: generated code check..."
make generate >/dev/null 2>&1
GENERATED_PATHS="apps/server/api/openapi.bundled.yaml \
    apps/server/internal/api/generated.go \
    apps/web/src/lib/api/gen \
    apps/web/src/lib/api/generated.ts"
if ! git diff --exit-code -- $GENERATED_PATHS; then
    echo ""
    echo "Generated code is stale — commit the output of: make generate"
    exit 1
fi

echo "pre-push: ok"
